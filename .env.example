# Copy this file to .env and fill in your actual Supabase project values.
# Get these from: Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# Optional: only needed if you want Google Sign-In
VITE_GOOGLE_CLIENT_ID=""
VITE_GOOGLE_AUTH_PROXY=""

# Optional: only used by the Design Arena sandbox auto-restore feature.
# Safe to leave blank for your own deployment.
FULLSTACK_PROJECT_REF=""
FULLSTACK_RESTORE_API_URL=""
